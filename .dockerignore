# Maven 编译产物（本地先 mvn package 再 docker build，需保留 fs-admin.jar）
# **/target/

# Node 模块（在容器内重新安装）
ui/node_modules/
ui/dist/

# IDE 和工具文件
.idea/
.vscode/
.kiro/
.git/
*.iml

# 本地运行时数据
data/
logs/

# LibreOffice 便携版（Linux 容器用系统 libreoffice）
LibreOfficePortable/

# 文档、图片资产（不参与构建）
_doc/
.images/

# 环境变量（不能打入镜像！）
.env

# 其他
*.log
*.tmp
